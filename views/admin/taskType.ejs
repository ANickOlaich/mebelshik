<%- include('partials/head'); -%>
<%- include('partials/top-menu'); -%>      
<%- include('partials/left-menu'); -%> 

<div class="row shadow p-3 mb-3 bg-body-tertiary rounded">
    <div class="row">
        <div class="col">  
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addTaskModal">
                 Добавить
            </button>    
        </div>
        
    </div>
</div>
                    
<div class="row shadow p-3 mb-3 bg-body-tertiary rounded">
    <table class="table m-2">
        <thead>
          <tr>
            <th scope="col">№</th>
            <th scope="col">Название</th>
            <th scope="col">Описание</th>
            <th scope="col">Фото</th>
            <th scope="col">Действия</th>
          </tr>
        </thead>
        <tbody>
          <tr v-for="(t,idx) in sortedTaskTypes">
            <th scope="row">{{t.sort}}</th>
            <td>{{t.name}}</td>
            <td>{{t.description}}</td>
            <td><img :src="t.image_url" width="100" class="img-thumbnail" :alt="t.name"></td>
            <td>
              <button class="btn btn-success" v-on:click="changeTypeTask(idx)">Редактировать</button>
              <button class="btn btn-danger" v-on:click="deleteTypeTask(idx)">Удалить</button>
            </td>
          </tr>
        </tbody>
      </table>
    </div>


      <!-- Modal -->
<div class="modal fade" id="addTaskModal" tabindex="-1" aria-labelledby="addTaskModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="addTaskModalLabel">Новое задание</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close">
                      <span aria-hidden="true">&times;</span>
                  </button>
        </div>
          <div class="modal-body ">
              <form>
                  <div class="mb-3">
                      <label for="name" class="col-form-label">Название</label>
                      <input 
                          type="text" 
                          class="form-control" 
                          id="name"
                          v-model="typeTask.name"
                      >
                  </div>
                  <div class="mb-3">
                      <label for="description" class="col-form-label">Описание</label>
                      <textarea 
                          class="form-control" 
                          id="description"
                          v-model="typeTask.description"
                      ></textarea>
                  </div>
                  <div class="mb-3">
                    <label for="name" class="col-form-label">Порядковый номер</label>
                    <input 
                        type="number" 
                        class="form-control" 
                        id="name"
                        v-model="typeTask.sort"
                        min="0" max="1000"
                    >
                </div>
                  
              </form>
          </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Закрыть</button>
          <button type="button" class="btn btn-primary" v-on:click="newTypeTask">Сохранить</button>
        </div>
      </div>
    </div>
  </div>

  

<%- include('partials/footer'); -%> 