<%- include('partials/head'); -%>
<%- include('partials/top-menu'); -%>      
<%- include('partials/left-menu'); -%> 

<div class="row shadow p-3 mb-3 bg-body-tertiary rounded">
    <div class="row">
        <div class="col">  
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addImageModal">
                 Добавить
            </button>    
        </div>
        
    </div>
</div>
                    
<div class="row shadow p-3 mb-3 bg-body-tertiary rounded">
    <table class="table m-2">
        <thead>
          <tr>
            <th scope="col">Описание</th>
            <th scope="col">Фото</th>
            <th scope="col">Действия</th>
          </tr>
        </thead>
        <tbody>
          <tr v-for="(t,idx) in gallery">
            <td>{{t.description}}</td>
            <td><img :src="t.image_url" width="100" class="img-thumbnail" :alt="t.name"></td>
            <td>
              <button class="btn btn-success" v-on:click="changeImage(idx)">Редактировать</button>
              <button class="btn btn-danger" v-on:click="deleteImage(idx)">Удалить</button>
            </td>
          </tr>
        </tbody>
      </table>
    </div>


      <!-- Modal -->
<div class="modal fade" id="addImageModal" tabindex="-1" aria-labelledby="addImageModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="addImageModalLabel">Новой эскиз</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close">
                      <span aria-hidden="true">&times;</span>
                  </button>
        </div>
          <div class="modal-body ">
              <form>
                <div class="mb-3">   
                    <img alt="Bootstrap Image Preview" class="img-fluid" :src="newImage.image_url" />
                </div>
                <div class="mb-3">
                    
                    <input 
                        type="file" 
                        @change="uploadImage" 
                        id="image"
                    />
                </div>
                <div class="mb-3">
                    <label for="description" class="col-form-label">Описание</label>
                    <textarea 
                        class="form-control" 
                        id="description"
                        v-model="newImage.description"
                    ></textarea>
                </div>
              </form>
          </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Закрыть</button>
          <button type="button" class="btn btn-primary" v-on:click="newImage">Сохранить</button>
        </div>
      </div>
    </div>
  </div>

  

<%- include('partials/footer'); -%> 