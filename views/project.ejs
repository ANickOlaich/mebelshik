<%- include('partials/header'); -%>
<%- include('partials/top-menu'); -%>
<div id="app">

    <div class="container-fluid">
        <div class="row">
            <div class="col-md-8">
               
                    <div class="form-group">  
                        <label>Имя проекта</label>
                        <input 
                            type="text" 
                            class="form-control" 
                            v-model="project.name"
                        />
                    </div>
                    <div class="form-group">  
                        <label>Описание проекта</label>
                        <textarea 
                            class="form-control" 
                            rows="3"
                            v-model="project.description"
                        ></textarea>
                    </div>
                    <div class="form-group">  
                        <label>Статус проекта</label>
                        <select 
                            class="form-select" 
                            v-model="project.status"
                            >
                            <option selected>{{project.status}}</option>
                            <option>Новый</option>
                            <option>В работе</option>
                            <option>В архиве</option>
                          </select>
                    </div>
                    <div class="form-check">
                        <input 
                            class="form-check-input" 
                            type="checkbox" 
                            value="" 
                            id="flexCheckDefault"
                            v-model="project.public"
                        >
                        <label class="form-check-label" for="flexCheckDefault">
                          На главной {{project.public}}
                        </label>
                    </div>
                    <div class="form-check">
                        <Label>Создан: {{project.createdAt}}</Label>
                    </div>
                    <div class="form-check">
                        <Label>Изменен: {{project.updatedAt}}</Label>
                    </div>
                    <hr>
                    <button 
                    
                        class="btn btn-primary"
                        v-on:click="updateProject"
                    >
                        Сохранить
                    </button>
                
            </div>
            <div class="col-md-4">
                <img alt="Bootstrap Image Preview" src="https://www.layoutit.com/img/sports-q-c-140-140-3.jpg" />
            </div>
        </div>
    </div>

</div>

</div>
</div>
</div>
</div>
<script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
<script src="/js/project.js"></script>
</body>

</html>
